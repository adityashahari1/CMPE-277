<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitleB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activity B"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvInfoB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Increase Thread Counter by 5"
        android:textSize="20sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvPauseCounterB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="onPause Count: 0"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvDestroyCounterB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="onDestroy Count: 0"
        android:textSize="18sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnFinishB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finish B" />

</LinearLayout>